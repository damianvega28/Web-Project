<div class="container my-5">
  <div class="text-center mb-4">
    <h1>Registrations</h1>
    <p>Browse event registrations in EventHub.</p>
  </div>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>User</th>
        <th>Event</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @registrations.each do |registration| %>
        <tr>
          <td><%= registration.user.name %></td>
          <td><%= link_to registration.event.title, event_path(registration.event) %></td>
          <td><%= registration.status.humanize %></td>
          <td>
            <div class="d-flex gap-2">
              <% if !registration.cancelled? && policy(registration).destroy? %>
                <%= button_to "Cancel",
                    registration_path(registration),
                    method: :delete,
                    class: "btn btn-sm btn-warning",
                    form: { data: { turbo_confirm: "Are you sure you want to cancel this registration?" } } %>
              <% end %>

              <% if policy(registration).show? %>
                <%= link_to "Show",
                    registration_path(registration),
                    class: "btn btn-sm btn-secondary" %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-4">
    <%= link_to "Back to Home",
        root_path,
        class: "btn",
        style: "background-color: #ce0615; color: white;" %>
  </div>
</div>