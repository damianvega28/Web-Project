<div class="container my-5">
  <div class="text-center mb-4">
    <h1>Registration</h1>
    <p>Registration details</p>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <p><strong>User:</strong> <%= link_to @registration.user.name, user_path(@registration.user) %></p>
      <p><strong>Event:</strong> <%= link_to @registration.event.title, event_path(@registration.event) %></p>
      <p><strong>Status:</strong> <%= @registration.status.humanize %></p>
    </div>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= link_to "Edit Registration", edit_registration_path(@registration), class: "btn btn-secondary" %>

    <%= button_to "Delete Registration",
                  registration_path(@registration),
                  method: :delete,
                  class: "btn btn-danger",
                  data: { turbo_confirm: "Are you sure you want to delete this registration?" } %>

    <%= link_to "Back to Registrations", registrations_path, class: "btn", style: "background-color: #ce0615; color: white;" %>
  </div>
</div>