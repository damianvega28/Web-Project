<div class="container my-5">
  <div class="text-center mb-4">
    <h1><%= @user.name %></h1>
    <p>User details</p>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <p><strong>Email:</strong> <%= @user.email %></p>
      <p><strong>Role:</strong> <%= @user.role.humanize %></p>
    </div>
  </div>

  <h2>Organized Events</h2>

  <ul class="list-group mb-4">
    <% @user.organized_events.each do |event| %>
      <% if policy(event).show? %>
        <li class="list-group-item">
          <%= link_to event.title, event_path(event) %>
          -
          <%= event.status.humanize %>
        </li>
      <% end %>
    <% end %>
  </ul>

  <h2>Registered Events</h2>

  <ul class="list-group mb-4">
    <% @user.events.each do |event| %>
      <% if policy(event).show? %>
        <li class="list-group-item">
          <%= link_to event.title, event_path(event) %>
          -
          <%= event.status.humanize %>
        </li>
      <% end %>
    <% end %>
  </ul>

  <h2>Reviews</h2>

  <ul class="list-group mb-4">
    <% @user.reviews.each do |review| %>
      <% if policy(review).show? %>
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <span>
            <%= link_to review.event.title, event_path(review.event) %>
            -
            <%= review.rating %>/5
          </span>

          <% if policy(review).destroy? %>
            <%= button_to "Delete Review",
                review_path(review),
                method: :delete,
                class: "btn btn-sm btn-danger",
                form: { data: { turbo_confirm: "Are you sure?" } } %>
          <% end %>
        </li>
      <% end %>
    <% end %>
  </ul>

  <h2>Notifications</h2>

  <ul class="list-group mb-4">
    <% @user.notifications.each do |notification| %>
      <% if policy(notification).show? %>
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <span>
            <%= link_to notification.title, notification_path(notification) %>
            -
            <%= notification.read ? "Read" : "Unread" %>
          </span>

          <% if !notification.read && policy(notification).update? %>
            <%= button_to "Mark as read",
                mark_as_read_notification_path(notification),
                method: :patch,
                class: "btn btn-sm btn-success" %>
          <% end %>
        </li>
      <% end %>
    <% end %>
  </ul>

  <% if policy(User).index? %>
    <%= link_to "Back to Users",
        users_path,
        class: "btn",
        style: "background-color: #ce0615; color: white;" %>
  <% else %>
    <%= link_to "Back to Home",
        root_path,
        class: "btn",
        style: "background-color: #ce0615; color: white;" %>
  <% end %>
</div>