<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h2 class="card-title mb-4">Edit User</h2>

          <%= form_with model: @user do |f| %>
            <% if @user.errors.any? %>
              <div class="alert alert-danger">
                <ul class="mb-0">
                  <% @user.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-3">
              <%= f.label :name, "Name", class: "form-label" %>
              <%= f.text_field :name, class: "form-control" %>
            </div>

            <div class="mb-3">
              <%= f.label :email, "Email", class: "form-label" %>
              <%= f.email_field :email, class: "form-control" %>
            </div>

            <% if policy(@user).permitted_attributes.include?(:role) %>
              <div class="mb-3">
                <%= f.label :role, "Role", class: "form-label" %>
                <%= f.select :role,
                    User.roles.keys.map { |r| [r.humanize, r] },
                    {},
                    class: "form-select" %>
              </div>
            <% end %>

            <%= f.submit "Save Changes",
                class: "btn w-100",
                style: "background-color: #ce0615; color: white;" %>
          <% end %>

          <div class="mt-3">
            <%= link_to "Cancel", user_path(@user), class: "btn btn-secondary w-100" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>