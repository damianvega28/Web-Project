<div class="container my-5">
  <div class="text-center mb-4">
    <h1>Users</h1>
    <p>Browse EventHub users.</p>
  </div>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Role</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td><%= user.name %></td>
          <td><%= user.email %></td>
          <td><%= user.role&.humanize %></td>
          <td>
            <div class="d-flex gap-2">
              <% if policy(user).show? %>
                <%= link_to "Show",
                    user_path(user),
                    class: "btn btn-sm btn-secondary" %>
              <% end %>

              <% if policy(user).update? %>
                <%= link_to "Edit",
                    edit_user_path(user),
                    class: "btn btn-sm btn-secondary" %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-4">
    <%= link_to "Back to Home",
        root_path,
        class: "btn",
        style: "background-color: #ce0615; color: white;" %>
  </div>
</div>