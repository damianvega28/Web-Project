<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>EventHub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

  <div class="container text-center my-5">
    <h1>Welcome to EventHub</h1>
    <p>Find and manage university events.</p>

    <%= link_to "Browse Events", events_path, class: "btn btn-primary", style: "background-color: #ce0615; color: white; border-color: white;" %>
  </div>

  <div class="container my-5">
    <h2>About</h2>
    <p>This platform is for our community members to create and discover events.</p>
  </div>

  <div class="container my-5">
    <h2>Contact</h2>
    <p>Email: contact@eventhub.com</p>
    <p>Phone: +56 9 2395 9999</p>
  </div>

  <footer class="bg-light text-center p-3">
    Atria, Córdova, Vega <br>
    Web Technologies 2026
  </footer>
</body>
</html>