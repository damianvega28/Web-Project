<div class="container my-5">
  <div class="text-center mb-4">
    <h1><%= @category.name %></h1>
    <p>Events in this category.</p>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h5 class="card-title">Description</h5>
      <p class="card-text"><%= @category.description %></p>
    </div>
  </div>

  <h2>Events</h2>

  <ul class="list-group mb-4">
    <% @category.events.each do |event| %>
      <% if policy(event).show? %>
        <li class="list-group-item">
          <%= link_to event.title, event_path(event) %>
          -
          <%= event.status.humanize %>
        </li>
      <% end %>
    <% end %>
  </ul>

  <div class="d-flex gap-2">
    <% if policy(@category).edit? %>
      <%= link_to "Edit Category",
          edit_category_path(@category),
          class: "btn btn-secondary" %>
    <% end %>

    <% if policy(@category).destroy? %>
      <%= button_to "Delete Category",
          category_path(@category),
          method: :delete,
          class: "btn btn-danger",
          form: { data: { turbo_confirm: "Are you sure you want to delete this category?" } } %>
    <% end %>

    <%= link_to "Back to Categories",
        categories_path,
        class: "btn",
        style: "background-color: #ce0615; color: white;" %>
  </div>
</div>