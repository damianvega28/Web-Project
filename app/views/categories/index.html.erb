<div class="container my-5">
  <div class="text-center mb-4">
    <h1>Categories</h1>
    <p>Browse event categories available in EventHub.</p>
  </div>

  <%= link_to "New Category", new_category_path, class: "btn btn-primary mb-3" %>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Name</th>
        <th>Description</th>
      </tr>
    </thead>

    <tbody>
      <% @categories.each do |category| %>
        <tr>
          <td><%= link_to category.name, category_path(category) %></td>
          <td><%= category.description %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-4">
    <%= link_to "Back to Home", root_path, class: "btn", style: "background-color: #ce0615; color: white;" %>
  </div>
</div>