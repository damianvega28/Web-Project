<div class="container my-5">
  <div class="text-center mb-4">
    <h1>Categories</h1>
    <p>Browse event categories available in EventHub.</p>
  </div>

  <% if policy(Category).new? %>
    <%= link_to "New Category",
        new_category_path,
        class: "btn mb-3",
        style: "background-color: #ce0615; color: white;" %>
  <% end %>

  <% show_actions = @categories.any? { |category| policy(category).edit? || policy(category).destroy? } %>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Name</th>
        <th>Description</th>

        <% if show_actions %>
          <th>Actions</th>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% @categories.each do |category| %>
        <tr>
          <td><%= link_to category.name, category_path(category) %></td>
          <td><%= category.description %></td>

          <% if show_actions %>
            <td>
              <div class="d-flex gap-2">
                <% if policy(category).edit? %>
                  <%= link_to "Edit",
                      edit_category_path(category),
                      class: "btn btn-sm btn-secondary" %>
                <% end %>

                <% if policy(category).destroy? %>
                  <%= button_to "Delete",
                      category_path(category),
                      method: :delete,
                      class: "btn btn-sm btn-danger",
                      form: { data: { turbo_confirm: "Are you sure?" } } %>
                <% end %>
              </div>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-4">
    <%= link_to "Back to Home",
        root_path,
        class: "btn",
        style: "background-color: #ce0615; color: white;" %>
  </div>
</div>