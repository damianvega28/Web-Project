<div class="container my-5">
  <div class="text-center mb-4">
    <h1><%= @notification.title %></h1>
    <p>Notification details</p>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <p><strong>User:</strong> <%= link_to @notification.user.name, user_path(@notification.user) %></p>
      <p><strong>Message:</strong> <%= @notification.message %></p>
      <p><strong>Type:</strong> <%= @notification.notification_type %></p>
      <p><strong>Read:</strong> <%= @notification.read ? "Yes" : "No" %></p>
    </div>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= link_to "Edit Notification", edit_notification_path(@notification), class: "btn btn-secondary" %>

    <% unless @notification.read %>
      <%= button_to "Mark as Read",
                    mark_as_read_notification_path(@notification),
                    method: :patch,
                    class: "btn btn-success" %>
    <% end %>

    <%= button_to "Delete Notification",
                  notification_path(@notification),
                  method: :delete,
                  class: "btn btn-danger",
                  data: { turbo_confirm: "Are you sure you want to delete this notification?" } %>

    <%= link_to "Back to Notifications", notifications_path, class: "btn", style: "background-color: #ce0615; color: white;" %>
  </div>
</div>