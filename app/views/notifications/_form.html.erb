<%= form_with model: @notification do |f| %>
  <% if @notification.errors.any? %>
    <div class="alert alert-danger">
      <h4>There were errors saving this notification:</h4>

      <ul>
        <% @notification.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :user_id, "User", class: "form-label" %>
    <%= f.collection_select :user_id, User.all, :id, :name,
        { prompt: "Select a user" },
        { class: "form-select", required: true } %>
  </div>

  <div class="mb-3">
    <%= f.label :title, "Title", class: "form-label" %>
    <%= f.text_field :title, class: "form-control", placeholder: "Enter notification title", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :message, "Message", class: "form-label" %>
    <%= f.text_area :message, class: "form-control", placeholder: "Enter notification message", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :notification_type, "Notification Type", class: "form-label" %>
    <%= f.select :notification_type,
        ["registration", "waitlist", "reminder", "event", "cancellation", "review"],
        { prompt: "Select notification type" },
        { class: "form-select", required: true } %>
  </div>

  <div class="form-check mb-3">
    <%= f.check_box :read, class: "form-check-input" %>
    <%= f.label :read, "Read", class: "form-check-label" %>
  </div>

  <%= f.submit "Save Notification", class: "btn", style: "background-color: #ce0615; color: white;" %>
<% end %>