<div class="container my-5">
  <div class="text-center mb-4">
    <h1>Notifications</h1>
    <p>Browse user notifications in EventHub.</p>
  </div>

  <div class="mb-3">
    <% if policy(Notification).new? %>
      <%= link_to "New Notification",
          new_notification_path,
          class: "btn",
          style: "background-color: #ce0615; color: white;" %>
    <% end %>
  </div>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>User</th>
        <th>Title</th>
        <th>Message</th>
        <th>Type</th>
        <th>Read</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @notifications.each do |notification| %>
        <tr>
          <td><%= notification.user.name %></td>
          <td><%= link_to notification.title, notification_path(notification) %></td>
          <td><%= truncate(notification.message, length: 80) %></td>
          <td><%= notification.notification_type %></td>
          <td><%= notification.read ? "Yes" : "No" %></td>
          <td>
            <div class="d-flex gap-2">
              <% if policy(notification).show? %>
                <%= link_to "Show",
                    notification_path(notification),
                    class: "btn btn-sm btn-secondary" %>
              <% end %>

              <% if !notification.read && policy(notification).update? %>
                <%= button_to "Mark as read",
                    mark_as_read_notification_path(notification),
                    method: :patch,
                    class: "btn btn-sm btn-success" %>
              <% end %>

              <% if policy(notification).edit? %>
                <%= link_to "Edit",
                    edit_notification_path(notification),
                    class: "btn btn-sm btn-secondary" %>
              <% end %>

              <% if policy(notification).destroy? %>
                <%= button_to "Delete",
                    notification_path(notification),
                    method: :delete,
                    class: "btn btn-sm btn-danger",
                    form: { data: { turbo_confirm: "Are you sure?" } } %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-4">
    <%= link_to "Back to Home",
        root_path,
        class: "btn",
        style: "background-color: #ce0615; color: white;" %>
  </div>
</div>