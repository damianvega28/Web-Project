<%= form_with model: @review do |f| %>
  <% if @review.errors.any? %>
    <div class="alert alert-danger">
      <h4>There were errors saving this review:</h4>

      <ul>
        <% @review.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :user_id, "User", class: "form-label" %>
    <%= f.collection_select :user_id, User.all, :id, :name,
        { prompt: "Select a user" },
        { class: "form-select", required: true } %>
  </div>

  <div class="mb-3">
    <%= f.label :event_id, "Event", class: "form-label" %>
    <%= f.collection_select :event_id, Event.all, :id, :title,
        { prompt: "Select an event" },
        { class: "form-select", required: true } %>
  </div>

  <div class="mb-3">
    <%= f.label :rating, "Rating", class: "form-label" %>
    <%= f.number_field :rating, class: "form-control", placeholder: "Enter rating from 1 to 5", required: true, min: 1, max: 5 %>
  </div>

  <div class="mb-3">
    <%= f.label :comment, "Comment", class: "form-label" %>
    <%= f.text_area :comment, class: "form-control", placeholder: "Write your review", required: true %>
  </div>

  <%= f.submit "Save Review", class: "btn", style: "background-color: #ce0615; color: white;" %>
<% end %>