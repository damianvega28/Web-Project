<div class="container my-5">
  <div class="text-center mb-4">
    <h1>Reviews</h1>
    <p>Browse event reviews in EventHub.</p>
  </div>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>User</th>
        <th>Event</th>
        <th>Rating</th>
        <th>Comment</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @reviews.each do |review| %>
        <tr>
          <td><%= review.user.name %></td>
          <td><%= link_to review.event.title, event_path(review.event) %></td>
          <td><%= review.rating %>/5</td>
          <td><%= link_to truncate(review.comment, length: 60), review_path(review) %></td>
          <td>
            <div class="d-flex gap-2">
              <% if policy(review).show? %>
                <%= link_to "Show",
                    review_path(review),
                    class: "btn btn-sm btn-secondary" %>
              <% end %>

              <% if policy(review).edit? %>
                <%= link_to "Edit",
                    edit_review_path(review),
                    class: "btn btn-sm btn-secondary" %>
              <% end %>

              <% if policy(review).destroy? %>
                <%= button_to "Delete",
                    review_path(review),
                    method: :delete,
                    class: "btn btn-sm btn-danger",
                    form: { data: { turbo_confirm: "Are you sure?" } } %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-4">
    <%= link_to "Back to Home",
        root_path,
        class: "btn",
        style: "background-color: #ce0615; color: white;" %>
  </div>
</div>