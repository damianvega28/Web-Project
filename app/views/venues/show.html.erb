<div class="container my-5">
  <div class="text-center mb-4">
    <h1><%= @venue.name %></h1>
    <p>Venue details</p>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <p><strong>Address:</strong> <%= @venue.address %></p>
      <p><strong>Capacity:</strong> <%= @venue.capacity %></p>
    </div>
  </div>

  <h2>Events</h2>

  <ul class="list-group mb-4">
    <% @venue.events.each do |event| %>
      <li class="list-group-item">
        <%= link_to event.title, event_path(event) %>
        -
        <%= event.status.humanize %>
      </li>
    <% end %>
  </ul>

  <div class="d-flex gap-2 mt-4">
    <%= link_to "Edit Venue", edit_venue_path(@venue), class: "btn btn-secondary" %>

    <%= button_to "Delete Venue",
                  venue_path(@venue),
                  method: :delete,
                  class: "btn btn-danger",
                  data: { turbo_confirm: "Are you sure you want to delete this venue?" } %>

    <%= link_to "Back to Venues", venues_path, class: "btn", style: "background-color: #ce0615; color: white;" %>
  </div>
</div>