<div class="container my-5">
  <div class="text-center mb-4">
    <h1>Venues</h1>
    <p>Browse event venues in EventHub.</p>
  </div>

  <div class="mb-3">
    <% if policy(Venue).new? %>
      <%= link_to "New Venue",
          new_venue_path,
          class: "btn",
          style: "background-color: #ce0615; color: white;" %>
    <% end %>
  </div>

  <% show_actions = @venues.any? { |venue| policy(venue).edit? || policy(venue).destroy? } %>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Name</th>
        <th>Address</th>
        <th>Capacity</th>

        <% if show_actions %>
          <th>Actions</th>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% @venues.each do |venue| %>
        <tr>
          <td><%= link_to venue.name, venue_path(venue) %></td>
          <td><%= venue.address %></td>
          <td><%= venue.capacity %></td>

          <% if show_actions %>
            <td>
              <div class="d-flex gap-2">
                <% if policy(venue).edit? %>
                  <%= link_to "Edit",
                      edit_venue_path(venue),
                      class: "btn btn-sm btn-secondary" %>
                <% end %>

                <% if policy(venue).destroy? %>
                  <%= button_to "Delete",
                      venue_path(venue),
                      method: :delete,
                      class: "btn btn-sm btn-danger",
                      form: { data: { turbo_confirm: "Are you sure?" } } %>
                <% end %>
              </div>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-4">
    <%= link_to "Back to Home",
        root_path,
        class: "btn",
        style: "background-color: #ce0615; color: white;" %>
  </div>
</div>