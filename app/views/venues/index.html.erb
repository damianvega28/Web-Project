<div class="container my-5">
  <div class="text-center mb-4">
    <h1>Venues</h1>
    <p>Browse event venues in EventHub.</p>
  </div>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Name</th>
        <th>Address</th>
        <th>Capacity</th>
      </tr>
    </thead>

    <tbody>
      <% @venues.each do |venue| %>
        <tr>
          <td><%= link_to venue.name, venue_path(venue) %></td>
          <td><%= venue.address %></td>
          <td><%= venue.capacity %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-4">
    <%= link_to "Back to Home", root_path, class: "btn", style: "background-color: #ce0615; color: white;" %>
  </div>
</div>