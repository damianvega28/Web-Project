<nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #ce0615;">
  <div class="container">
    <%= link_to "EventHub", root_path, class: "navbar-brand" %>

    <div class="navbar-nav ms-auto">
      <% if policy(Event).index? %>
        <%= link_to "Events", events_path, class: "nav-link" %>
      <% end %>

      <% if policy(Category).index? %>
        <%= link_to "Categories", categories_path, class: "nav-link" %>
      <% end %>

      <% if policy(Venue).index? %>
        <%= link_to "Venues", venues_path, class: "nav-link" %>
      <% end %>

      <% if policy(Review).index? %>
        <%= link_to "Reviews", reviews_path, class: "nav-link" %>
      <% end %>

      <% if user_signed_in? %>
        <% if policy(Registration).index? %>
          <%= link_to "Registrations", registrations_path, class: "nav-link" %>
        <% end %>

        <% if policy(Notification).index? %>
          <%= link_to "Notifications", notifications_path, class: "nav-link" %>
        <% end %>

        <% if policy(User).index? %>
          <%= link_to "Users", users_path, class: "nav-link" %>
        <% end %>

        <span class="navbar-text text-white ms-3">
          <%= current_user.name.presence || current_user.email %>
        </span>

        <%= button_to "Log out",
            destroy_user_session_path,
            method: :delete,
            class: "btn btn-outline-light btn-sm ms-2" %>
      <% else %>
        <%= link_to "Sign up", new_user_registration_path, class: "nav-link" %>
        <%= link_to "Log in", new_user_session_path, class: "nav-link" %>
      <% end %>
    </div>
  </div>
</nav>