<%= form_with model: @event do |f| %>
  <% if @event.errors.any? %>
    <div class="alert alert-danger">
      <h4>There were errors saving this event:</h4>

      <ul>
        <% @event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, "Title", class: "form-label" %>
    <%= f.text_field :title, class: "form-control", placeholder: "Enter event title", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :category_id, "Category", class: "form-label" %>
    <%= f.collection_select :category_id, Category.all, :id, :name,
        { prompt: "Select a category" },
        { class: "form-select", required: true } %>
  </div>

  <div class="mb-3">
    <%= f.label :venue_id, "Venue", class: "form-label" %>
    <%= f.collection_select :venue_id, Venue.all, :id, :name,
        { prompt: "Select a venue" },
        { class: "form-select", required: true } %>
  </div>

  <div class="mb-3">
    <%= f.label :creator_id, "Organizer", class: "form-label" %>
    <%= f.collection_select :creator_id, User.all, :id, :name,
        { prompt: "Select an organizer" },
        { class: "form-select", required: true } %>
  </div>

  <div class="mb-3">
    <%= f.label :start_date, "Start Date", class: "form-label" %>
    <%= f.datetime_local_field :start_date, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :end_date, "End Date", class: "form-label" %>
    <%= f.datetime_local_field :end_date, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :capacity, "Capacity", class: "form-label" %>
    <%= f.number_field :capacity, class: "form-control", placeholder: "Enter event capacity", required: true, min: 1 %>
  </div>

  <div class="mb-3">
    <%= f.label :description, "Description", class: "form-label" %>
    <%= f.rich_text_area :description, class: "form-control" %>
  </div>

  <%= f.submit "Save Event", class: "btn", style: "background-color: #ce0615; color: white;" %>
<% end %>