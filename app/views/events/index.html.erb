<div class="container my-5">
  <div class="text-center mb-4">
    <h1>Events</h1>
    <p>Browse university events available in EventHub.</p>
  </div>

  <div class="mb-3">
    <% if policy(Event).new? %>
      <%= link_to "New Event",
          new_event_path,
          class: "btn",
          style: "background-color: #ce0615; color: white;" %>
    <% end %>
  </div>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Title</th>
        <th>Description</th>
        <th>Start date</th>
        <th>End date</th>
        <th>Capacity</th>
        <th>Status</th>
        <th>Category</th>
        <th>Venue</th>
        <th>Creator</th>

        <% if current_user&.admin? %>
          <th>Actions</th>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% @events.each do |event| %>
        <%
          badge_class = case event.status
          when "draft"      then "bg-secondary"
          when "published"  then "bg-success"
          when "ongoing"    then "bg-primary"
          when "completed"  then "bg-dark"
          when "cancelled"  then "bg-danger"
          end
        %>

        <tr>
          <td><%= link_to event.title, event_path(event) %></td>
          <td><%= truncate(strip_tags(event.description.to_s), length: 80) %></td>
          <td><%= event.start_date.strftime("%B %d, %Y %H:%M") %></td>
          <td><%= event.end_date.strftime("%B %d, %Y %H:%M") %></td>
          <td><%= event.capacity %></td>
          <td><span class="badge <%= badge_class %>"><%= event.status.humanize %></span></td>
          <td><%= event.category.name %></td>
          <td><%= event.venue.name %></td>
          <td><%= event.creator.name %></td>

          <% if current_user&.admin? %>
            <td>
              <div class="d-flex gap-2">
                <% if policy(event).edit? %>
                  <%= link_to "Edit",
                      edit_event_path(event),
                      class: "btn btn-sm btn-secondary" %>
                <% end %>

                <% if policy(event).destroy? %>
                  <%= button_to "Delete",
                      event_path(event),
                      method: :delete,
                      form: { data: { turbo_confirm: "Are you sure?" } },
                      class: "btn btn-sm btn-danger" %>
                <% end %>
              </div>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-4">
    <%= link_to "Back to Home",
        root_path,
        class: "btn",
        style: "background-color: #ce0615; color: white;" %>
  </div>
</div>