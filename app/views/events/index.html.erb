<div class="container my-5">
  <div class="text-center mb-4">
    <h1>Events</h1>
    <p>Browse university events available in EventHub.</p>
  </div>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Title</th>
        <th>Description</th>
        <th>Start date</th>
        <th>End date</th>
        <th>Capacity</th>
        <th>Status</th>
        <th>Category</th>
        <th>Venue</th>
        <th>Creator</th>
      </tr>
    </thead>

    <tbody>
      <% @events.each do |event| %>
        <tr>
          <td><%= link_to event.title, event_path(event) %></td>
          <td><%= truncate(event.description, length: 80) %></td>
          <td><%= event.start_date.strftime("%B %d, %Y %H:%M") %></td>
          <td><%= event.end_date.strftime("%B %d, %Y %H:%M") %></td>
          <td><%= event.capacity %></td>
          <td><%= event.status.humanize %></td>
          <td><%= event.category.name %></td>
          <td><%= event.venue.name %></td>
          <td><%= event.creator.name %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="mt-4">
    <%= link_to "Back to Home", root_path, class: "btn", style: "background-color: #ce0615; color: white;" %>
  </div>
</div>